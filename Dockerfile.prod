FROM node:18-alpine AS build

WORKDIR /app

# Accept build argument for backend URL
ARG REACT_APP_URL

COPY frontend/package*.json ./

RUN npm install

COPY frontend/ .

# Build with the URL passed as environment variable
RUN REACT_APP_URL=${REACT_APP_URL} npm run build

FROM node:18-alpine

WORKDIR /app

RUN npm install -g serve

COPY --from=build /app/build ./build

EXPOSE 3000

CMD ["serve", "-s", "build", "-l", "3000"]
